#!/usr/bin/env bash

set -euo pipefail

current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [[ "$current_branch" == "main" ]]; then
  echo "ERROR: Commits to 'main' are blocked."
  echo "Create or switch to a feature branch before committing."
  echo "Example: git switch -c feature/my-change"
  exit 1
fi

